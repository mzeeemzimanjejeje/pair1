{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node ./scripts/preinstall.js",
    "build": "cd artifacts/api-server && npm install --legacy-peer-deps",
    "heroku-postbuild": "cd artifacts/api-server && npm install --legacy-peer-deps",
    "start": "node artifacts/api-server/index.js",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@whiskeysockets/baileys",
      "protobufjs",
      "bufferutil",
      "utf-8-validate"
    ]
  },
  "engines": {
    "node": "20.x",
    "npm": ">=9.7.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.2",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.4",
    "lightningcss-win32-x64-msvc": "^1.32.0"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "npm:wileys@^0.5.1",
    "body-parser": "^1.20.4",
    "express": "^4.22.1",
    "pino": "^8.21.0"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
