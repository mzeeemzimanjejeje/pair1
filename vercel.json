{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/pairing-site run build && pnpm run build && cp -r ../pairing-site/dist/public ./dist/public",
  "builds": [
    {
      "src": "dist/index.mjs",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "includeFiles": ["dist/public/**"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "dist/index.mjs" }
  ]
}
