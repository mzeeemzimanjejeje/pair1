{
  "version": 2,
  "installCommand": "cd artifacts/api-server && npm install --legacy-peer-deps",
  "builds": [
    {
      "src": "artifacts/api-server/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "artifacts/api-server/*.html",
          "artifacts/api-server/*.js"
        ],
        "maxDuration": 60
      }
    }
  ],
  "functions": {
    "artifacts/api-server/index.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/index.js"
    }
  ]
}
