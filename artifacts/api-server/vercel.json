{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "../{index.js,pair.js,store.js,id.js,pair.html,validate.html}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
